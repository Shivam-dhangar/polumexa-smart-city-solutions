# ─── AI Chatbot (Polly) ──────────────────────────────────────────────────────
# Powers real AI responses in the Polly chat widget.
# Get your key at: https://console.anthropic.com
# Without this key, Polly uses smart keyword-based fallback responses.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Contact Form ────────────────────────────────────────────────────────────
# Sends contact form submissions to your email via Formspree (free tier: 50/mo).
# Setup: 1) Create account at https://formspree.io
#        2) Create a new form → copy the form ID (e.g. "xaybqpzw")
#        3) Paste it below (just the ID, not the full URL)
# Without this, the form opens the user's mail client as a fallback.
VITE_FORMSPREE_ID=your_formspree_form_id_here
